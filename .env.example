# Copy to .env.local for local dev, and set these in Vercel Project Settings → Environment Variables.

# Resend API key — used by the contact form and the interview-summary email.
# Create one at https://resend.com/api-keys
RESEND_API_KEY=

# Recipient address for contact-form submissions and interview summaries.
CONTACT_EMAIL=j.xue0816@gmail.com

# Verified "from" address for Resend. Until you verify your own domain, you can
# use Resend's onboarding sender: onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev

# Google Gemini API key for the Interviewer agent.
# Create one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
